<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <script>const t = localStorage.getItem('theme') || 'dark'; document.documentElement.setAttribute('data-theme', t);</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كورة لايف - مشاهدة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/mpegts.js@latest/dist/mpegts.min.js"></script>
    <link rel="stylesheet" href="style.css">
    <style>
        .watch-container { max-width: 1000px; margin: 20px auto; padding: 0 15px; }
        .video-box { background: #000; border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; position: relative; }
        #player { width: 100%; height: 100%; display: block; }

        /* زر التشغيل الكبير */
        #play-overlay {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            cursor: pointer; z-index: 5;
            transition: background 0.3s;
        }
        #play-overlay:hover { background: linear-gradient(135deg, #1e293b, #334155); }
        #play-overlay .play-btn {
            width: 80px; height: 80px;
            background: rgba(99,102,241,0.9);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 32px; color: #fff;
            box-shadow: 0 0 40px rgba(99,102,241,0.5);
            transition: transform 0.2s, box-shadow 0.2s;
            margin-bottom: 16px;
        }
        #play-overlay:hover .play-btn {
            transform: scale(1.1);
            box-shadow: 0 0 60px rgba(99,102,241,0.7);
        }
        #play-overlay p { color: #94a3b8; font-family: 'Cairo', sans-serif; font-size: 15px; }

        /* رسالة الخطأ */
        #error-box {
            display: none; position: absolute; inset: 0;
            background: rgba(0,0,0,0.9); color: #fff;
            flex-direction: column; align-items: center; justify-content: center;
            text-align: center; padding: 20px; gap: 10px; z-index: 10;
            font-family: 'Cairo', sans-serif;
        }
        #err-msg { font-size: 13px; opacity: 0.7; max-width: 400px; word-break: break-all; direction: ltr; text-align: left; }
    </style>
</head>
<body>
    <header class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo"><i class="fa-solid fa-play"></i><span> كورة لايف</span></a>
        </div>
    </header>

    <div class="watch-container">
        <div class="video-box">
            <!-- زر التشغيل في المنتصف -->
            <div id="play-overlay" onclick="startStream()">
                <div class="play-btn"><i class="fa-solid fa-play" style="margin-right:-4px;"></i></div>
                <p>اضغط لبدء المشاهدة</p>
            </div>

            <!-- رسالة الخطأ -->
            <div id="error-box">
                <i class="fa-solid fa-circle-exclamation" style="font-size:40px; color:#f87171;"></i>
                <h3>فشل تشغيل البث</h3>
                <p id="err-msg"></p>
                <button onclick="document.getElementById('error-box').style.display='none'; document.getElementById('play-overlay').style.display='flex';"
                    style="margin-top:10px; padding:8px 20px; background:#6366f1; border:none; border-radius:8px; color:#fff; cursor:pointer; font-family:Cairo,sans-serif;">
                    إعادة المحاولة
                </button>
            </div>

            <video id="player" controls playsinline style="width:100%;height:100%;display:block;"></video>
        </div>
    </div>

    <script>
        const STREAM_URL = "{{STREAM_URL}}";
        let streamStarted = false;

        function showError(msg) {
            document.getElementById('err-msg').textContent = msg;
            document.getElementById('error-box').style.display = 'flex';
        }

        function needsProxy(url) {
            try {
                const parsed = new URL(url);
                const port = parsed.port;
                const isNonStandardPort = port && port !== '80' && port !== '443';
                return parsed.protocol === 'http:' || isNonStandardPort;
            } catch(e) { return false; }
        }

        function startStream() {
            if (streamStarted) return;
            streamStarted = true;

            const video = document.getElementById('player');
            const overlay = document.getElementById('play-overlay');
            overlay.style.display = 'none';

            const url = STREAM_URL;
            if (!url || url === '{{STREAM_URL}}') {
                showError('No stream URL provided');
                return;
            }

            const finalUrl = needsProxy(url)
                ? `/proxy?url=${encodeURIComponent(url)}`
                : url;

            console.log("Starting stream:", finalUrl);

            if (url.includes('.m3u8')) {
                if (Hls.isSupported()) {
                    const hls = new Hls();
                    hls.loadSource(finalUrl);
                    hls.attachMedia(video);
                    hls.on(Hls.Events.MANIFEST_PARSED, () => video.play());
                    hls.on(Hls.Events.ERROR, (e, data) => {
                        if (data.fatal) showError(`HLS ${data.type}: ${data.details}`);
                    });
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = finalUrl;
                    video.play();
                }
            } else {
                // بث MPEG-TS - نستخدم mpegts.js
                let tsTimeout = setTimeout(() => {
                    showError('Stream timeout: السيرفر لا يرسل بيانات أو البصيغة غير مدعومة');
                }, 15000);

                if (typeof mpegts !== 'undefined' && mpegts.getFeatureList().mseLivePlayback) {
                    const player = mpegts.createPlayer({
                        type: 'mpegts',
                        isLive: true,
                        url: finalUrl
                    });
                    player.attachMediaElement(video);
                    player.load();
                    player.on(mpegts.Events.MEDIA_INFO, () => {
                        clearTimeout(tsTimeout);
                        video.play().catch(() => {});
                    });
                    player.on(mpegts.Events.ERROR, (type, detail) => {
                        clearTimeout(tsTimeout);
                        showError(`mpegts Error: ${type} - ${JSON.stringify(detail)}`);
                    });
                } else {
                    // fallback للمتصفحات التي لا تدعم mpegts
                    video.src = finalUrl;
                    video.onerror = () => {
                        clearTimeout(tsTimeout);
                        const codes = {1:'ABORTED', 2:'NETWORK', 3:'DECODE', 4:'SRC_NOT_SUPPORTED'};
                        showError(`Video Error ${video.error?.code}: ${codes[video.error?.code] || 'Unknown'}`);
                    };
                    video.play().catch(e => {
                        if (e.name !== 'NotAllowedError') {
                            clearTimeout(tsTimeout);
                            showError(`Play Error: ${e.message}`);
                        }
                    });
                }
            }
        }
    </script>
</body>
</html>