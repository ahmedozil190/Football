<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <script>const t = localStorage.getItem('theme') || 'dark'; document.documentElement.setAttribute('data-theme', t);</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كورة لايف - مشاهدة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <link rel="stylesheet" href="style.css">
    <style>
        .watch-container { max-width: 1000px; margin: 20px auto; padding: 0 15px; }
        .video-box { background: #000; border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; position: relative; }
        #player { width: 100%; height: 100%; }
        #error-box { display: none; position: absolute; inset: 0; background: rgba(220,38,38,0.9); color: #fff; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
    </style>
</head>
<body>
    <header class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo"><i class="fa-solid fa-play"></i><span> كورة لايف</span></a>
        </div>
    </header>

    <div class="watch-container">
        <div class="video-box">
            <div id="error-box">
                <i class="fa-solid fa-circle-exclamation" style="font-size:40px; margin-bottom:10px;"></i>
                <h3 id="error-title">فشل تشغيل البث</h3>
                <p id="error-msg" style="font-size:13px; opacity:0.8; max-width:400px; word-break:break-all;"></p>
            </div>
            <video id="player" controls autoplay playsinline></video>
        </div>
    </div>

    <script>
        const STREAM_URL = "{{STREAM_URL}}";

        function showError(msg) {
            const errBox = document.getElementById('error-box');
            document.getElementById('error-msg').textContent = msg || '';
            errBox.style.display = 'flex';
        }

        function loadStream(url) {
            const video = document.getElementById('player');
            
            if (!url || url === '{{STREAM_URL}}') {
                showError('لم يتم تحديد رابط البث');
                return;
            }

            // HTTPS يشتغل مباشرة، HTTP يمر عبر البروكسي
            const finalUrl = url.startsWith('http://') 
                ? `/proxy?url=${encodeURIComponent(url)}` 
                : url;
            
            console.log("Playing:", finalUrl);

            if (url.includes('.m3u8')) {
                if (Hls.isSupported()) {
                    const hls = new Hls();
                    hls.loadSource(finalUrl);
                    hls.attachMedia(video);
                    hls.on(Hls.Events.MANIFEST_PARSED, () => video.play());
                    hls.on(Hls.Events.ERROR, (e, data) => {
                        if (data.fatal) showError(`HLS Error: ${data.type} - ${data.details}`);
                    });
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = finalUrl;
                    video.play();
                }
            } else {
                // للروابط المباشرة (TS/HTTP): نجرب أولاً ونعرض الخطأ الحقيقي
                fetch(finalUrl, { method: 'GET' })
                    .then(r => {
                        if (!r.ok) return r.text().then(t => showError(`Server: ${r.status} - ${t}`));
                        video.src = finalUrl;
                        video.play().catch(e => showError(`Player Error: ${e.message}`));
                    })
                    .catch(e => showError(`Network Error: ${e.message}`));
            }
        }

        document.addEventListener('DOMContentLoaded', () => loadStream(STREAM_URL));
    </script>
</body>
</html>