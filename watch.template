<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <script>const t = localStorage.getItem('theme') || 'dark'; document.documentElement.setAttribute('data-theme', t);</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كورة لايف - مشاهدة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <link rel="stylesheet" href="style.css">
    <style>
        .watch-container { max-width: 1000px; margin: 20px auto; padding: 0 15px; }
        .video-box { background: #000; border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; position: relative; }
        #player { width: 100%; height: 100%; display: block; }
        #error-box { display: none; position: absolute; inset: 0; background: rgba(0,0,0,0.85); color: #fff; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 20px; gap: 10px; }
    </style>
</head>
<body>
    <header class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo"><i class="fa-solid fa-play"></i><span> كورة لايف</span></a>
        </div>
    </header>

    <div class="watch-container">
        <div class="video-box">
            <div id="error-box">
                <i class="fa-solid fa-circle-exclamation" style="font-size:40px;"></i>
                <h3 id="err-title">فشل تشغيل البث</h3>
                <p id="err-msg" style="font-size:13px; opacity:0.8; max-width:400px; word-break:break-all; direction:ltr; text-align:left;"></p>
            </div>
            <video id="player" controls autoplay playsinline></video>
        </div>
    </div>

    <script>
        const STREAM_URL = "{{STREAM_URL}}";

        function showError(msg) {
            document.getElementById('err-msg').textContent = msg;
            document.getElementById('error-box').style.display = 'flex';
        }

        function loadStream(url) {
            console.log("loadStream called with:", url);
            const video = document.getElementById('player');

            if (!url || url.trim() === '' || url === '{{STREAM_URL}}') {
                showError('No stream URL provided');
                return;
            }

            // أي رابط يحتوي على port غير قياسي أو http يمر عبر البروكسي
            function needsProxy(u) {
                try {
                    const parsed = new URL(u);
                    const port = parsed.port;
                    const isNonStandardPort = port && port !== '80' && port !== '443';
                    return parsed.protocol === 'http:' || isNonStandardPort;
                } catch(e) { return false; }
            }

            const finalUrl = needsProxy(url)
                ? `/proxy?url=${encodeURIComponent(url)}` 
                : url;

            console.log("Final URL:", finalUrl);

            if (url.includes('.m3u8')) {
                if (Hls.isSupported()) {
                    const hls = new Hls();
                    hls.loadSource(finalUrl);
                    hls.attachMedia(video);
                    hls.on(Hls.Events.MANIFEST_PARSED, () => {
                        console.log("HLS manifest parsed, playing...");
                        video.play();
                    });
                    hls.on(Hls.Events.ERROR, (e, data) => {
                        console.error("HLS Error:", data);
                        if (data.fatal) showError(`HLS ${data.type}: ${data.details}`);
                    });
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = finalUrl;
                    video.play();
                } else {
                    showError('HLS not supported in this browser');
                }
            } else {
                // بث مباشر TS
                video.src = finalUrl;
                video.onerror = (e) => {
                    const codes = { 1:'ABORTED', 2:'NETWORK', 3:'DECODE', 4:'SRC_NOT_SUPPORTED' };
                    showError(`Video Error ${video.error?.code}: ${codes[video.error?.code] || 'Unknown'} - ${video.error?.message || ''}`);
                };
                video.play().catch(e => showError(`Play Error: ${e.message}`));
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            console.log("Page loaded. STREAM_URL =", STREAM_URL);
            loadStream(STREAM_URL);
        });
    </script>
</body>
</html>