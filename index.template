<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <script>const t = localStorage.getItem('theme') || 'dark'; document.documentElement.setAttribute('data-theme', t);</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كورة لايف - شاهد جميع المباريات بأعلي جودة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <style>
        .empty-state { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; color: #fff; gap: 16px; text-align: center; width: 100%; }
        .visitor-grid { display: none !important; }
        .visitor-grid.active { display: grid !important; }
        .team-logo-img { width: 60px; height: 60px; object-fit: contain; }
    </style>
</head>
<body>
    <header class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo"><i class="fa-solid fa-play"></i><span> كورة لايف</span></a>
            <nav class="nav-links">
                <a href="/" class="active"><i class="fa-solid fa-house"></i> الرئيسية</a>
            </nav>
            <div class="nav-right">
                <button id="theme-toggle" class="nav-icon-btn"><i class="fa-solid fa-moon"></i></button>
            </div>
        </div>
    </header>

    <div class="main-content-wrapper">
        <section class="hero-banner">
            <h1>شاهد جميع المباريات بأعلي جودة وبدون تقطيع</h1>
            <p>تابع جميع المباريات مباشرة من مكان واحد وبأفضل تجربة مشاهدة.</p>
        </section>

        <section class="matches-section">
            <div class="section-header">
                <h2 id="match-day-title">أهم مباريات اليوم</h2>
                <div class="day-tabs-visitor">
                    <button class="day-tab-v" onclick="showDay('yesterday', this)">مباريات الأمس</button>
                    <button class="day-tab-v active" onclick="showDay('today', this)">مباريات اليوم</button>
                    <button class="day-tab-v" onclick="showDay('tomorrow', this)">مباريات الغد</button>
                </div>
            </div>
            <div id="grid-yesterday" class="matches-grid visitor-grid"></div>
            <div id="grid-today" class="matches-grid visitor-grid active"></div>
            <div id="grid-tomorrow" class="matches-grid visitor-grid"></div>
        </section>
    </div>

    {{MATCHES_INJECTION}}

    <script>
        function renderMatches() {
            const grids = { yesterday: document.getElementById('grid-yesterday'), today: document.getElementById('grid-today'), tomorrow: document.getElementById('grid-tomorrow') };
            const counts = { yesterday: 0, today: 0, tomorrow: 0 };
            if (typeof allMatches !== 'undefined') {
                allMatches.forEach(m => {
                    const day = m.day || 'today';
                    if (!grids[day]) return;
                    counts[day]++;
                    const card = `
                        <a href="watch.php?id=${m.id}" class="match-card-wrapper" style="text-decoration:none; color:inherit; display:block;">
                            <div class="match-card ${m.status}">
                                <div class="match-main-info">
                                    <div class="match-team home"><img class="team-logo-img" src="${m.homeLogo}"><span>${m.homeTeam}</span></div>
                                    <div class="match-center-details">
                                        <div class="match-score-center"><span>${m.awayScore} - ${m.homeScore}</span></div>
                                        <div class="match-status-badge">${m.status_text}</div>
                                    </div>
                                    <div class="match-team away"><span>${m.awayTeam}</span><img class="team-logo-img" src="${m.awayLogo}"></div>
                                </div>
                            </div>
                        </a>`;
                    grids[day].innerHTML += card;
                });
            }
            for (let d in grids) if (counts[d] === 0) grids[d].innerHTML = '<div class="empty-state">لا توجد مباريات</div>';
        }
        function showDay(day, el) {
            document.querySelectorAll('.visitor-grid').forEach(g => g.classList.remove('active'));
            document.querySelectorAll('.day-tab-v').forEach(t => t.classList.remove('active'));
            document.getElementById('grid-' + day).classList.add('active');
            if(el) el.classList.add('active');
        }
        document.addEventListener('DOMContentLoaded', renderMatches);
    </script>
</body>
</html>